# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Sustainability & Cost Integration Platform"

# Security
SECRET_KEY=sustainabilitycostintegrationsecretkey12345
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sustainability_db

# Redis / Task Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Carbon Intensity (Simulated gCO2/kWh)
AWS_US_EAST_1_INTENSITY=350
AZURE_WEST_EUROPE_INTENSITY=220
GCP_US_CENTRAL_1_INTENSITY=410

# Monitoring
PROMETHEUS_METRICS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Grafana Dashboard
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=admin
